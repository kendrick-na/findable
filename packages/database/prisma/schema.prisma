// Findable v1.0 데이터 모델
// PRD §10 기준. RLS·Drizzle 마이그레이션은 v2.0 (D-006)
// next-forge 기본 Prisma 7.x + Neon Postgres + @prisma/adapter-neon

generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider     = "postgresql"
  relationMode = "prisma"
}

// ──────────────────────────────────────────────────
// 조직 + 사용자 (Clerk 연동)
// ──────────────────────────────────────────────────

model Organization {
  id                 String   @id @default(uuid())
  name               String
  ownerId            String // Clerk user_id
  plan               Plan     @default(free)
  planExpiresAt      DateTime?
  trialEndsAt        DateTime?
  billingStatus      BillingStatus @default(trialing)
  billingCustomerId  String? // Toss billingKey 또는 PayPal payerId
  billingProvider    BillingProvider?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  users    User[]
  brands   Brand[]
  reports  Report[]

  @@index([ownerId])
}

model User {
  id             String   @id // Clerk user_id
  email          String   @unique
  name           String?
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime @default(now())

  @@index([organizationId])
}

// ──────────────────────────────────────────────────
// 브랜드 + 프롬프트
// ──────────────────────────────────────────────────

model Brand {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  domain         String
  industry       Industry?
  language       BrandLanguage @default(both)
  competitors    Json     @default("[]") // [{ name, domain }]
  entityVariants Json     @default("[]") // ["아모레", "Amorepacific", "아모레퍼시픽"] — Korean Entity Grounding
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  prompts   Prompt[]
  trackings Tracking[]
  reports   Report[]

  @@index([organizationId])
  @@index([domain])
}

model Prompt {
  id              String   @id @default(uuid())
  brandId         String
  brand           Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  text            String
  language        PromptLanguage
  category        PromptCategory?
  isAutoGenerated Boolean  @default(false)
  createdAt       DateTime @default(now())

  trackings Tracking[]

  @@index([brandId])
}

// ──────────────────────────────────────────────────
// 엔진 (시드 데이터, 7개 + α)
// ──────────────────────────────────────────────────

model Engine {
  id        String  @id // chatgpt, claude, perplexity, gemini, hyperclova, naver, daum
  name      String
  provider  EngineProvider
  language  EngineLanguage
  isActive  Boolean @default(true)
  ordering  Int     @default(0)

  trackings Tracking[]
}

// ──────────────────────────────────────────────────
// 추적 결과 (모든 엔진 호출의 raw + 분석)
// ──────────────────────────────────────────────────

model Tracking {
  id              String   @id @default(uuid())
  brandId         String
  brand           Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  promptId        String
  prompt          Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  engineId        String
  engine          Engine   @relation(fields: [engineId], references: [id])
  rawResponse     String?  @db.Text
  brandMentioned  Boolean  @default(false)
  mentionPosition Int? // 1, 2, 3, ...
  sentiment       Sentiment?
  citedSources    Json     @default("[]") // [{ url, domain, title? }]
  shareOfVoice    Float? // 0.0 ~ 1.0
  errorMessage    String? // 호출 실패 시
  trackedAt       DateTime @default(now())

  @@index([brandId])
  @@index([promptId])
  @@index([engineId])
  @@index([brandId, trackedAt])
}

// ──────────────────────────────────────────────────
// 리포트 (Audit · Weekly · Monthly · Custom)
// ──────────────────────────────────────────────────

model Report {
  id             String   @id @default(uuid())
  brandId        String?
  brand          Brand?   @relation(fields: [brandId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           ReportType
  pdfUrl         String?
  data           Json? // SoV·Sentiment·시계열·경쟁사 비교 등
  generatedAt    DateTime @default(now())

  @@index([brandId])
  @@index([organizationId])
}

// ──────────────────────────────────────────────────
// 무료 Audit 잡 (PLG 진입점, 비로그인)
// ──────────────────────────────────────────────────

model AuditJob {
  id          String   @id @default(uuid())
  email       String
  domain      String
  industry    Industry?
  language    BrandLanguage @default(both)
  status      AuditStatus @default(queued)
  pdfUrl      String?
  result      Json? // SoV · 경쟁사 비교 · Top 3 추천 (휴리스틱 빠른 모드)

  // 강화 모드 (4 에이전트 분석) — 옵션
  crewStatus   CrewStatus @default(not_requested)
  crewResult   Json? // 민지·Alex·수진·준호 4 에이전트 리포트
  crewStartedAt DateTime?
  crewCompletedAt DateTime?

  errorMessage String?
  ipAddress   String? // 어뷰즈 방지 (rate limit)
  createdAt   DateTime @default(now())
  completedAt DateTime?

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

enum CrewStatus {
  not_requested
  queued
  processing
  completed
  failed
}

// ──────────────────────────────────────────────────
// 리드 (CRM 진입)
// ──────────────────────────────────────────────────

model Lead {
  id        String   @id @default(uuid())
  email     String
  domain    String?
  source    LeadSource
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([email])
}

// ──────────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────────

enum Plan {
  free
  starter
  growth
  scale
  enterprise
}

enum BillingStatus {
  active
  trialing
  past_due
  canceled
  expired
}

enum BillingProvider {
  toss
  paypal
  wire
}

enum Industry {
  beauty
  fashion
  food
  b2b_saas
  content_ip
  retail
  finance
  healthcare
  education
  other
}

enum BrandLanguage {
  ko
  en
  both
}

enum PromptLanguage {
  ko
  en
}

enum PromptCategory {
  best_in_category
  alternative
  comparison
  recommendation
  problem_solving
  buying_guide
  custom
}

enum EngineProvider {
  openai
  anthropic
  perplexity
  google
  naver
  kakao
}

enum EngineLanguage {
  ko
  en
  both
}

enum Sentiment {
  positive
  neutral
  negative
}

enum ReportType {
  free_audit
  weekly
  monthly
  custom
}

enum AuditStatus {
  queued
  processing
  completed
  failed
}

enum LeadSource {
  free_audit
  contact_form
  newsletter
  referral
  other
}
